#!/bin/sh
set -e
if ! wp core is-installed 2>/dev/null; then
  wp core install --url="localhost:8080" --title="OCF WordPress Template" --admin_user=admin --admin_password="$(tr -dc '[:alnum:]' < /dev/urandom | head -c256)" --admin_email="wp-admin@ocf.berkeley.edu" --allow-root
fi
php-fpm -p / &&
nginx -c /conf/wp-nginx.conf
